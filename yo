-- ============================================
-- UPDATE LOOP
-- ============================================
local function StartUpdateLoop()
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not ScreenGui or not ScreenGui.Parent then
            connection:Disconnect()
            return
        end

        if OverlayStats and OverlayStats.Parent then
            if ShowFPS then
                local fps = UpdateFPS()
                if fps then
                    local lbl = OverlayStats:FindFirstChild("FPSLabel")
                    if lbl then lbl.Text = "FPS: " .. fps end
                end
            end
            if ShowPing then
                local ping = UpdatePing()
                local lbl = OverlayStats:FindFirstChild("PingLabel")
                if lbl then lbl.Text = "Ping: " .. ping .. "ms" end
            end
        end
    end)
end

-- ============================================
-- INPUT BINDING
-- ============================================
local function SetupInputBinding()
    if not UIBindEnabled then return end
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            if MainFrame then
                MainFrame.Visible = not MainFrame.Visible
                if MainFrame.Visible then
                    Tween(MainFrame, {Size = UDim2.new(0, 520, 0, 420)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                end
            end
        end
    end)
end

-- ============================================
-- PET SCANNING
-- ============================================
local function StartPetScanning()
    spawn(function()
        while ScreenGui and ScreenGui.Parent do
            wait(1)
            if math.random(1, 10) == 1 then
                local randomPet = BlacklistPets[math.random(1, #BlacklistPets)]
                local moneyValue = math.random(1, 1000)

                if moneyValue >= MinMoney then
                    AddLog("Pet found: " .. randomPet .. " (Value: $" .. moneyValue .. ")")

                    if ShowBlacklist and table.find(BlacklistPets, randomPet) then
                        AddLog("Skipped: " .. randomPet .. " (Blacklisted)")
                    elseif ShowAutoForce and table.find(AutoForcePets, randomPet) then
                        AddLog("Auto-joining for: " .. randomPet)
                    end
                end
            end
        end
    end)
end

-- ============================================
-- ANTI-LAG / ERROR
-- ============================================
local function SetupAntiLag()
    if not AntiLag then return end
    print("Anti-Lag enabled")
end

local function SetupAntiError()
    if not AntiError then return end
    local ok = pcall(function()
        local old = getrawmetatable(game).__namecall
        setreadonly(getrawmetatable(game), false)
        getrawmetatable(game).__namecall = newcclosure(function(self, ...)
            local ok2, res = pcall(old, self, ...)
            if not ok2 then warn("Error caught: " .. tostring(res)) end
            return res
        end)
        setreadonly(getrawmetatable(game), true)
    end)
    if ok then print("Anti-Error enabled") end
end

