function AddLog(message)
    if not LogScrollingFrame or not LogScrollingFrame.Parent then return end

    local LogEntry = Instance.new("Frame")
    LogEntry.Size = UDim2.new(1, 0, 0, 0)
    LogEntry.AutomaticSize = Enum.AutomaticSize.Y
    LogEntry.BackgroundTransparency = 1
    LogEntry.Parent = LogScrollingFrame

    local timeLabel = Instance.new("TextLabel")
    timeLabel.Size = UDim2.new(0, 50, 0, 18)
    timeLabel.BackgroundTransparency = 1
    timeLabel.Text = os.date("%H:%M:%S")
    timeLabel.TextColor3 = Theme.TextMuted
    timeLabel.TextScaled = false
    timeLabel.TextSize = 11
    timeLabel.Font = Enum.Font.Gotham
    timeLabel.TextXAlignment = Enum.TextXAlignment.Left
    timeLabel.Parent = LogEntry

    local msgLabel = Instance.new("TextLabel")
    msgLabel.Size = UDim2.new(1, -55, 0, 0)
    msgLabel.AutomaticSize = Enum.AutomaticSize.Y
    msgLabel.Position = UDim2.new(0, 55, 0, 0)
    msgLabel.BackgroundTransparency = 1
    msgLabel.Text = message
    msgLabel.TextColor3 = Theme.TextPrimary
    msgLabel.TextScaled = false
    msgLabel.TextSize = 13
    msgLabel.Font = Enum.Font.Gotham
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.TextWrapped = true
    msgLabel.Parent = LogEntry

    -- Update entry height based on text
    local textBounds = TextService:GetTextSize(message, 13, Enum.Font.Gotham, Vector2.new(LogScrollingFrame.AbsoluteSize.X - 75, 1000))
    LogEntry.Size = UDim2.new(1, 0, 0, math.max(20, textBounds.Y + 4))

    -- Update log count
    local logCount = MainFrame and MainFrame:FindFirstChild("ContentFrame", true) and 
        MainFrame:FindFirstChild("ContentFrame", true):FindFirstChild("LogFrame") and 
        MainFrame:FindFirstChild("ContentFrame", true):FindFirstChild("LogFrame"):FindFirstChild("LogCount")
    if logCount then
        local count = 0
        for _ in ipairs(LogScrollingFrame:GetChildren()) do count = count + 1 end
        logCount.Text = count .. " entries"
    end

    -- Auto-scroll
    delay(0.1, function()
        if LogScrollingFrame and LogScrollingFrame.Parent then
            LogScrollingFrame.CanvasPosition = Vector2.new(0, LogScrollingFrame.AbsoluteCanvasSize.Y)
        end
    end)
end

-- Main Frame Event Handlers
local function SetupMainFrameEvents()
    if not MainFrame then return end

    local closeBtn = MainFrame:FindFirstChild("CloseButton", true)
    if closeBtn then
        closeBtn.MouseButton1Click:Connect(function()
            TweenObject(MainFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
            wait(0.3)
            if ScreenGui then ScreenGui:Destroy() end
            ScreenGui = nil
        end)
    end

    local minimizeBtn = MainFrame:FindFirstChild("MinimizeButton", true)
    if minimizeBtn then
        minimizeBtn.MouseButton1Click:Connect(function()
            TweenObject(MainFrame, {Size = UDim2.new(0, MainFrame.Size.X.Offset * 0.8, 0, 0)}, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
            wait(0.3)
            MainFrame.Visible = false
            if not MiniFrame then CreateMiniFrame() end
            MiniFrame.Visible = true
        end)
    end

    local filterBtn = MainFrame:FindFirstChild("FilterButton", true)
    if filterBtn then
        filterBtn.MouseButton1Click:Connect(function()
            CreateFilterFrame()
        end)
    end
end

-- Update Loop for FPS/Ping
local function StartUpdateLoop()
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not ScreenGui or not ScreenGui.Parent then
            connection:Disconnect()
            return
        end

        if OverlayStats and OverlayStats.Parent then
            if ShowFPS then
                local fps = UpdateFPS()
                if fps then
                    local fpsLabel = OverlayStats:FindFirstChild("FPSLabel")
                    if fpsLabel then fpsLabel.Text = "FPS: " .. fps end
                end
            end

            if ShowPing then
                local ping = UpdatePing()
                local pingLabel = OverlayStats:FindFirstChild("PingLabel")
                if pingLabel then pingLabel.Text = "Ping: " .. ping .. "ms" end
            end
        end
    end)
end

-- Input Binding
local function SetupInputBinding()
    if not UIBindEnabled then return end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            if MainFrame then
                MainFrame.Visible = not MainFrame.Visible
                if MainFrame.Visible then
                    TweenObject(MainFrame, {Size = UDim2.new(0, 520, 0, 460)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                end
            end
        end
    end)
end

-- Pet Scanning Logic
local function StartPetScanning()
    spawn(function()
        while ScreenGui and ScreenGui.Parent do
            wait(1)
            if math.random(1, 10) == 1 then
                local randomPet = BlacklistPets[math.random(1, #BlacklistPets)]
                local moneyValue = math.random(1, 1000)

                if moneyValue >= MinMoney then
                    AddLog("Pet found: " .. randomPet .. " (Value: $" .. moneyValue .. ")")

                    if ShowBlacklist and table.find(BlacklistPets, randomPet) then
                        AddLog("Skipped: " .. randomPet .. " (Blacklisted)")
                        if TierNotifications then
                            ShowNotification("Pet Skipped", randomPet .. " is blacklisted", "warning", 3)
                        end
                    elseif ShowAutoForce and table.find(AutoForcePets, randomPet) then
                        AddLog("Auto-joining for: " .. randomPet)
                        if TierNotifications then
                            ShowNotification("Auto-Force Triggered", "Joining for " .. randomPet, "success", 4)
                        end
                    end
                end
            end
        end
    end)
end

-- Anti-Lag / Error Handling
local function SetupAntiLag()
    if not AntiLag then return end
    print("Anti-Lag enabled - reduced render cycles")
end

local function SetupAntiError()
    if not AntiError then return end
    local success = pcall(function()
        local oldNamecall = getrawmetatable(game).__namecall
        setreadonly(getrawmetatable(game), false)
        getrawmetatable(game).__namecall = newcclosure(function(self, ...)
            local args = {...}
            local method = getnamecallmethod()
            local success, result = pcall(oldNamecall, self, ...)
            if not success then
                warn("Error caught: " .. tostring(result))
            end
            return result
        end)
        setreadonly(getrawmetatable(game), true)
    end)
    if success then print("Anti-Error enabled") end
end

