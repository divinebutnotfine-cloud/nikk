-- Update Loop for FPS/Ping and Effects
local function StartUpdateLoop()
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not ScreenGui or not ScreenGui.Parent then
            connection:Disconnect()
            return
        end

        -- Update FPS
        if OverlayStats and ShowFPS then
            local fps = UpdateFPS()
            if fps > 0 then
                OverlayStats.FPSLabel.Text = "FPS: " .. fps
            end
        end

        -- Update Ping
        if OverlayStats and ShowPing then
            local ping = UpdatePing()
            OverlayStats.PingLabel.Text = "Ping: " .. ping .. "ms"
        end
    end)
end

-- Input Binding (Right Control to Toggle UI)
local function SetupInputBinding()
    if not UIBindEnabled then return end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            if MainFrame then
                MainFrame.Visible = not MainFrame.Visible
            end
        end
    end)
end

